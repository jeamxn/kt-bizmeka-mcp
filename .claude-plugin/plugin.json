{
  "name": "kt-bizmeka",
  "version": "0.2.0",
  "description": "KT 비즈메카 EZ 자동화 — RSA 로그인/SMS 2차인증/SAML SSO + 웹메일(목록/상세/발송/답장/수신확인/발송취소). Bun standalone 바이너리.",
  "author": {
    "name": "jeamxn"
  },
  "homepage": "https://github.com/jeamxn/kt-bizmeka-mcp",
  "repository": "https://github.com/jeamxn/kt-bizmeka-mcp",
  "license": "MIT",
  "keywords": ["bizmeka", "kt", "webmail", "saml", "korea"],
  "mcpServers": {
    "kt-bizmeka": {
      "type": "http",
      "url": "https://bizmeka-mcp.jeamxn.dev/mcp"
    },
    "kt-bizmeka-local": {
      "command": "node",
      "args": ["${CLAUDE_PLUGIN_ROOT}/scripts/launcher.cjs"],
      "env": {
        "MCP_TRANSPORT": "stdio"
      }
    }
  }
}
